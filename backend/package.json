{
  "name": "kampuskart-backend",
  "version": "1.0.0",
  "description": "Backend server for KampusKart - MIT ADT University's campus portal",
  "main": "server.js",
  "scripts": {
    "build": "node -e \"process.exit(0)\"",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:integration": "jest --testPathPattern=integration.test.js$",
    "lint": "eslint .",
    "test:local": "node -e \"process.env.NODE_ENV='test'; require('child_process').spawnSync('jest', { stdio: 'inherit', shell: true, env: process.env })\"",
    "test-keep-alive": "node scripts/test-keep-alive.js",
    "setup-uptime": "node scripts/setup-uptime-monitoring.js",
    "seed": "node scripts/seedData.js"
  },
  "keywords": [
    "campus",
    "portal",
    "university",
    "express",
    "mongodb"
  ],
  "author": "KampusKart Team",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.1",
    "multer": "^2.0.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.0.7",
    "nodemailer": "^7.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.8.1",
    "streamifier": "^0.1.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.26",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
